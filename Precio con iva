ALGORITMO Precio_con_IVA
    Definir precio, cantidad, subtotal, iva, total Como Real
    Escribir "Ingrese el precio de la licencia:"
    Leer precio
    Escribir "Ingrese la cantidad vendida:"
    Leer cantidad
    subtotal <- precio * cantidad
    iva <- subtotal * 0.19
    total <- subtotal + iva
    Escribir "Subtotal:", subtotal
    Escribir "IVA 19%:", iva
    Escribir "Total a pagar:", total
FIN ALGORITMO
